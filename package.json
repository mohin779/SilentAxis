{
  "name": "silentaxis-backend",
  "version": "1.0.0",
  "private": true,
  "description": "SilentAxis anonymous enterprise whistleblower platform backend",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "predev": "node scripts/kill-port.js 4000",
    "dev": "ts-node-dev --respawn --exit-child --transpile-only src/server.ts",
    "start": "node dist/server.js",
    "test": "jest --runInBand",
    "seed:demo": "ts-node --transpile-only src/scripts/seedDemo.ts",
    "zk:compile": "circom zk/circuits/complaintProof.circom --r1cs --wasm --sym -o zk/build && snarkjs groth16 setup zk/build/complaintProof.r1cs zk/build/powersOfTau28_hez_final_12.ptau zk/build/complaintProof_0000.zkey && snarkjs zkey contribute zk/build/complaintProof_0000.zkey zk/build/complaintProof.zkey --name=\"SilentAxis Contributor\" -v -e=\"silentaxis-entropy\" && snarkjs zkey export verificationkey zk/build/complaintProof.zkey zk/build/verification_key.json",
    "zk:proof": "ts-node --transpile-only zk/scripts/generateProof.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.872.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.7.8",
    "circomlibjs": "^0.1.7",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.19.0",
    "ffjavascript": "^0.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.5",
    "pg": "^8.12.0",
    "snarkjs": "^0.7.5",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.7.4",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "jest": "^30.2.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
